{
  "name": "@onborn/rn-sdk",
  "version": "0.1.0-beta.3",
  "description": "React Native SDK for rendering Onborn onboarding flows and paywalls.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onborn/onborn-react-native.git",
    "directory": "packages/rn-sdk"
  },
  "bugs": {
    "url": "https://github.com/onborn/onborn-react-native/issues"
  },
  "homepage": "https://github.com/onborn/onborn-react-native#readme",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal": {
      "react-native": "./dist/internal.js",
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/config/**/*.js",
    "dist/config/**/*.d.ts",
    "dist/core/**/*.js",
    "dist/core/**/*.d.ts",
    "dist/hooks/**/*.js",
    "dist/hooks/**/*.d.ts",
    "dist/paywall/**/*.js",
    "dist/paywall/**/*.d.ts",
    "dist/renderer/**/*.js",
    "dist/renderer/**/*.d.ts",
    "dist/ui/**/*.js",
    "dist/ui/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo-google-fonts/merriweather": "^0.4.2",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/open-sans": "^0.4.2",
    "@expo-google-fonts/oswald": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo-google-fonts/raleway": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo-google-fonts/schibsted-grotesk": "^0.4.2",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@onborn/analytics": "0.1.0-beta.2",
    "@onborn/billing": "0.1.0-beta.2",
    "@onborn/sdk-contracts": "0.1.0-beta.1",
    "@react-native-async-storage/async-storage": "^3.0.3",
    "@tamagui/config": "^2.0.0-rc.42",
    "@tamagui/core": "^2.0.0-rc.42",
    "expo-font": "~57.0.0",
    "expo-blur": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-localization": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-video": "~57.0.0",
    "phosphor-react-native": "^3.0.6",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-svg": "^15.12.0",
    "tamagui": "^2.0.0-rc.42"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "lottie-react-native": ">=7.0.0",
    "react-native": ">=0.86.0",
    "react-native-reanimated": ">=4.5.0",
    "react-native-worklets": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "lottie-react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "~19.2.4",
    "eslint": "^9.39.1",
    "react-native-reanimated": "4.5.0",
    "react-native-worklets": "0.10.0",
    "typescript": "5.9.2"
  }
}
